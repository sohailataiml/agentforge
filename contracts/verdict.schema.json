{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentforge.local/contracts/verdict.schema.json",
  "title": "Verdict",
  "description": "Judge Agent -> Orchestrator, Documentation Agent. result='fail' means the TARGET failed to stay secure (i.e. a confirmed exploit), not that the attack failed.",
  "type": "object",
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "attempt_id": { "type": "string", "format": "uuid" },
    "result": { "type": "string", "enum": ["pass", "fail", "partial"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "rubric_id": { "type": "string", "minLength": 1 },
    "rubric_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "rationale": { "type": "string", "minLength": 1 },
    "is_regression": { "type": "boolean" },
    "regressed_case_id": { "type": ["string", "null"] },
    "escalate_to_human": { "type": "boolean" },
    "severity": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low", "info"]
    },
    "judged_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "schema_version",
    "attempt_id",
    "result",
    "confidence",
    "rubric_id",
    "rubric_version",
    "rationale",
    "is_regression",
    "escalate_to_human",
    "severity"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "confidence": { "maximum": 0.6 } } },
      "then": { "properties": { "escalate_to_human": { "const": true } } }
    }
  ]
}
