{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentforge.local/contracts/eval_result.schema.json",
  "title": "EvalResult",
  "description": "Eval Runner -> run log / Judge. One case executed live against the deployed target. In Phase 3 `result` is set by each step's deterministic detector; in Phase 4 the Judge becomes authoritative for cases with requires_judge=true.",
  "type": "object",
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "case_id": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "result": {
      "type": "string",
      "enum": ["pass", "fail", "partial", "error"],
      "description": "'fail' = the TARGET failed to stay secure (exploit confirmed), matching contracts/verdict.schema.json's convention. 'error' = a step could not be executed (target unreachable, bad input)."
    },
    "expected_result": { "type": "string", "enum": ["pass", "fail", "partial"] },
    "surprise": {
      "type": "boolean",
      "description": "true when result != expected_result — a should-hold defense that broke, or a known finding that no longer reproduces. The signal the Orchestrator and regression harness care about most."
    },
    "requires_judge": { "type": "boolean" },
    "authority": {
      "type": "string",
      "enum": ["detector", "judge_pending", "judge"],
      "description": "Who owns this verdict. 'detector' = deterministic result is final for this case. 'judge_pending' = requires_judge case whose coarse detector result is provisional (no Judge ran). 'judge' = the Phase 4 Judge produced the authoritative result in `verdict`."
    },
    "verdict": {
      "type": "object",
      "description": "The authoritative Verdict (contracts/verdict.schema.json) when authority='judge'. Absent when no Judge ran.",
      "properties": {
        "result": { "type": "string", "enum": ["pass", "fail", "partial"] },
        "confidence": { "type": "number" },
        "rubric_id": { "type": "string" },
        "rubric_version": { "type": "string" },
        "rationale": { "type": "string" },
        "severity": { "type": "string" },
        "escalate_to_human": { "type": "boolean" }
      },
      "required": ["result", "confidence", "rationale", "escalate_to_human"]
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "step_id": { "type": "string", "minLength": 1 },
          "patient_id": { "type": "string", "minLength": 1 },
          "session_id": { "type": ["string", "null"] },
          "result": { "type": "string", "enum": ["pass", "fail", "partial", "error", "setup"] },
          "detector_matched": { "type": ["boolean", "null"] },
          "observed_behavior": { "type": "string" },
          "input_sequence": {
            "type": "array",
            "description": "The attack turns sent to the target for this step.",
            "items": {
              "type": "object",
              "properties": {
                "turn": { "type": "integer" },
                "role": { "type": "string" },
                "content": { "type": "string" },
                "doc_type": { "type": "string" }
              },
              "required": ["turn", "role", "content"],
              "additionalProperties": false
            }
          },
          "error": { "type": ["string", "null"] }
        },
        "required": ["step_id", "patient_id", "result", "observed_behavior"],
        "additionalProperties": false
      }
    },
    "cost": {
      "type": "object",
      "properties": {
        "tokens": { "type": "integer", "minimum": 0 },
        "usd": { "type": "number", "minimum": 0 }
      },
      "required": ["tokens", "usd"],
      "additionalProperties": false
    },
    "target_system_version": { "type": "string" },
    "executed_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "schema_version",
    "case_id",
    "category",
    "result",
    "expected_result",
    "surprise",
    "requires_judge",
    "authority",
    "steps",
    "cost",
    "executed_at"
  ],
  "additionalProperties": false
}
