{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentforge.local/contracts/attack_directive.schema.json",
  "title": "AttackDirective",
  "description": "Orchestrator -> Red Team Agent. Assigns a scoped attack campaign.",
  "type": "object",
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "directive_id": { "type": "string", "format": "uuid" },
    "attack_category": {
      "type": "string",
      "enum": [
        "prompt_injection",
        "data_exfiltration",
        "state_corruption",
        "tool_misuse",
        "dos",
        "identity_role"
      ]
    },
    "subcategory": { "type": "string", "minLength": 1 },
    "owasp_refs": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "seed_cases": {
      "type": "array",
      "items": { "type": "string" }
    },
    "strategy_hint": {
      "type": "string",
      "pattern": "^(novel|multi_turn|mutate:.+)$"
    },
    "token_budget": { "type": "integer", "minimum": 1 },
    "max_turns": { "type": "integer", "minimum": 1, "maximum": 50 },
    "priority": {
      "type": "string",
      "enum": ["critical", "high", "medium", "low"]
    },
    "issued_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "schema_version",
    "directive_id",
    "attack_category",
    "subcategory",
    "owasp_refs",
    "token_budget",
    "max_turns",
    "priority"
  ],
  "additionalProperties": false
}
